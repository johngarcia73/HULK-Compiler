123;

function factorial(n: Number): Number {
    if (n == 0) {
        return 1;
    } else {
        return n * factorial(n - 1);
    }
}

function square(x: Number) => x * x;

function hypotenuse(a: Number, b: Number): Number {
    return sqrt(square(a) + square(b));
}

function max(x: Number, y: Number): Number {
    if (x > y) {
        return x;
    } else {
        return y;
    }
}

function ex(x:Number): Number{
    123 + 123.4;
    return 0;
}

let a = 5 in let b = 12 in let sum = a+b in print(sum);

let msg = "The sum is: " @ "a" in print(msg);

print("Factorial of 5 is: ");
let fact = factorial(5) in print(fact);

print("Max of 10 and 20 is: ");
let m = max(10, 20) in print(m);

print("Absolute value of -42 is: ");
let absVal = abs(-42) in print(absVal);

print("sin(0) is: ");
let sinVal = sin(0) in print(sinVal);


let number = 42, text = "The meaning of life is" in print(text @ number);

let number = 42 in let text = "The meaning of life is" in print(text @ number);

let number = 42 in (let text = "The meaning of life is" in (print(text @ number)));

let a = 42 in if (a % 2 == 0) print("Even") else print("odd");

let a = 42 in print(if (a % 2 == 0) "even" else "odd");

let a = 42 in
    if (a % 2 == 0) {
        print(a);
        print("Even");
    }
    else print("Odd");

let a = 42, let mod = a % 3 in
    print(
        if (mod == 0) "Magic"
        elif (mod % 3 == 1) "Woke"
        else "Dumb"
    );

let countdown = 5 in while (countdown >= 0) {
    print(countdown);
    countdown := countdown - 1;
};

function gcd(a: Number, b: Number) => while (a > 0)
    let m = a % b in {
        b := a;
        a := m;
    };

print("gcd(48, 18) is: ");
print(gcd(48, 18));

for (x in range(0, 5)) print(x);

let a = 10 in while (a >= 0) {
    print(a);
    a := a - 1;
};

type Point(x: Number, y: Number) {
    x: Number = x;
    y: Number = y;
    getX(): Number => self.x;
    getY(): Number => self.y;
    describe(): String => "Point(" @ self.getX() @ ", " @ self.getY() @ ")";
}

type LabeledPoint(x: Number, y: Number, label: String) inherits Point(x, y) {
    label: String = label;
    describe(): String => base() @ " " @ self.label;
}

let point: Point = new Point(3, 4) in print(point.describe());

let obj: Point = new LabeledPoint(1, 2, "A") in
    print(if (obj is LabeledPoint) (obj as LabeledPoint).describe() else "none");

protocol Hashable {
    hash(): Number;
}

protocol Named extends Hashable {
    describe(): String;
}

type Person(name: String) {
    name: String = name;
    hash(): Number => 1;
    describe(): String => self.name;
}

function showNamed(item: Named): String => item.describe();
function hashValue(item: Hashable): Number => item.hash();
function twice(n) => n + n;

type Counter(seed) {
    current = seed + 1;
    value(): Number => self.current;
}

let person: Named = new Person("Ada") in print(showNamed(person));
let alias: Hashable = new Person("Grace") in print(hashValue(alias));
print(twice(21));
let counter = new Counter(4) in print(counter.value());

function sum(numbers: Number*): Number =>
    let total: Number = 0 in
        for (x in numbers)
            total := total + x;

function mean(numbers: Number[]): Number =>
    let total: Number = 0 in {
        for (x in numbers)
            total := total + x;
        total / numbers.size();
    };

protocol NumberFilter {
    invoke(x: Number): Bool;
}

function count_when(numbers: Number*, filter: (Number) -> Bool): Number =>
    let total: Number = 0 in
        for (x in numbers)
            total := total + (if (filter(x)) 1 else 0);

function is_even(x: Number): Bool => x % 2 == 0;

let numbers = [1, 2, 3, 4, 5] in {
    print(sum(numbers));
    print(mean(numbers));
    print(numbers[2]);
};

let squares = [x * x | x in range(1, 6)] in {
    print(sum(squares));
    print(squares.size());
};

let numbers = range(0, 10) in
    print(count_when(numbers, is_even));

let numbers = [1, 2, 3, 4] in
    print(count_when(numbers, (x: Number): Bool => x % 2 == 0));

