

export function w $main() {
@start
    #Initialize GC
    call $_hulk_gc_init()
    #Handle print function call
    %num_literal1 =d copy d_0
    %_i1 = d copy %num_literal1 
    @loop_cond1
        %num_literal2 =d copy d_5
        %less_than1 = w cltd %_i1, %num_literal2
        jnz %less_than1,@loop_body1,@loop_end1
    @loop_body1
        %num_literal3 =d copy d_1
        %addition1 = d add %_i1, %num_literal3
        %_i1 = d copy %addition1
        %block_result1 = d copy %addition1
        jmp @loop_cond1
    @loop_end1
        #This label is used just for mark of the end loop
        #this comment is to make that clear
    %block_result2 = d copy %block_result1
    %let_in_result1 = d copy %block_result2
    %print_arg_str1 = l call $_d_to_string(d %let_in_result1,w 1)
    %print_result1 = l call $_print(l %print_arg_str1)
    ret 0
}
