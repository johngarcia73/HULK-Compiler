

export function d $_add( d %_a1, d %_b1){
@start
    %addition1 = d add %_a1, %_b1
    ret %addition1
}

export function w $main() {
@start
    #Initialize GC
    call $_hulk_gc_init()
    #Handle print function call
    %num_literal1 =d copy d_5
    %num_literal2 =d copy d_10
    %call_result1 = d call $_add( d %num_literal1, d %num_literal2)
    %print_arg_str1 = l call $_d_to_string(d %call_result1,w 1)
    %print_result1 = l call $_print(l %print_arg_str1)
    ret 0
}
