data $string_literal_pointer0 = align 16 { w 16, b "Five is greather", b 0}
data $string_literal_pointer1 = align 16 { w 15, b "Ten is greather", b 0}


export function w $main() {
@start
    #Initialize GC
    call $_hulk_gc_init()
    %num_literal1 =d copy d_5
    %num_literal2 =d copy d_10
    %greater_than1 = w cgtd %num_literal1, %num_literal2
    jnz %greater_than1,@then1,@else1
    
    @then1
        #Handle print function call
        %string_literal_pointer0 = l copy $string_literal_pointer0
        %print_arg_str1 = l call $_l_to_string(l %string_literal_pointer0,w 3)
        %print_result1 = l call $_print(l %print_arg_str1)
        %if_result1 = l copy %print_result1
        jmp @merge1
    @else1
        #Handle print function call
        %string_literal_pointer1 = l copy $string_literal_pointer1
        %print_arg_str2 = l call $_l_to_string(l %string_literal_pointer1,w 3)
        %print_result2 = l call $_print(l %print_arg_str2)
        %if_result1= l copy %print_result2
    @merge1
    ret 0
}
