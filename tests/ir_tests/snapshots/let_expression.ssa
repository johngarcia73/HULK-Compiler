data $string_literal_pointer0 = align 16 { w 20, b "Outer scope variable", b 0}
data $string_literal_pointer1 = align 16 { w 20, b "Inner scope variable", b 0}


export function w $main() {
@start
    #Initialize GC
    call $_hulk_gc_init()
    %string_literal_pointer0 = l copy $string_literal_pointer0
    %_x1 = l copy %string_literal_pointer0 
    #Handle print function call
    %print_arg_str1 = l call $_l_to_string(l %_x1,w 3)
    %print_result1 = l call $_print(l %print_arg_str1)
    %string_literal_pointer1 = l copy $string_literal_pointer1
    %_x2 = l copy %string_literal_pointer1 
    #Handle print function call
    %print_arg_str2 = l call $_l_to_string(l %_x2,w 3)
    %print_result2 = l call $_print(l %print_arg_str2)
    %let_in_result1 = l copy %print_result2
    #Handle print function call
    %print_arg_str3 = l call $_l_to_string(l %_x1,w 3)
    %print_result3 = l call $_print(l %print_arg_str3)
    %block_result1 = l copy %print_result3
    %let_in_result2 = l copy %block_result1
    ret 0
}
